{
  "$schema": "../node_modules/@tauri-apps/cli/schema/desktop-capability.json",
  "identifier": "default",
  "description": "Default capabilities for Shadow — includes tray icon permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:tray:default",
    "dialog:allow-open",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
